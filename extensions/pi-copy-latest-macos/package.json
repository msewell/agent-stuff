{
  "name": "pi-copy-latest-macos",
  "version": "0.1.0",
  "description": "Minimal pi extension: /copy copies the latest assistant output to macOS clipboard",
  "type": "module",
  "license": "GPL-3.0-only",
  "keywords": [
    "pi-package",
    "pi-extension",
    "clipboard",
    "copy"
  ],
  "files": [
    "extensions/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "tsx --test test/**/*.test.ts",
    "coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines 80 npm test"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "c8": "^10.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
